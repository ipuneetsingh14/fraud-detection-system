# Copy this file to ".env" and fill in the values.

# Port the Node backend listens on
PORT=5000

# Secret used to sign JWT auth tokens. Use any long random string.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# URL of the Python ML service
ML_SERVICE_URL=http://localhost:8000

# Where the dashboard runs (used for CORS)
CLIENT_URL=http://localhost:5173

# SQLite file path. Leave as-is for zero-config local dev.
DB_FILE=./fraud.db
